{
  "expo": {
    "name": "project-alpha",
    "slug": "project-alpha",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "projectalpha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.projectalpha.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6E7EA"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
